<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium Job Application</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="background-circles">
        <div class="circle circle-2"></div>
        </div>
        <div class="container">
            <form id="app-form" class="glass-form">
                <h2>Job Application</h2>
                <p>joining your enginnering team</p>
                <div class="input-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" placeholder="Enter your name"required>
        </div>
        <div class="input-group">
            <label for="email">Email Address</label>
             <input type="email" id="email" placeholder="example@mail.com" required>
        </div>
        <div class="input-group">
            <label for="role">Appliying For</label>
            <select id="role">
                <option value="fronted">Fronted Developer</option>
                <option value="python">python Developer</option>
                <option value="software-eng">Software engeineer</option>
            </select>
        </div>
        <div class="input-group">
            <label for="message">Why should we hire you?</label>
            <textarea id="message" rows="4" placeholder="Briefly describe your skills..."></textarea>
        </div>
        <button type="submit" class="submit-btn">Send Application</button>
        </form>
        </div>
</body>
</html>
