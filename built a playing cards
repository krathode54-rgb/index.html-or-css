<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Playing Cards</title>

<style>
body {
    margin: 0;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
    font-family: Arial, sans-serif;
}

.container {
    display: flex;
    gap: 20px;
}

/* Card Style */
.card {
    width: 120px;
    height: 170px;
    perspective: 1000px;
}

.inner {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 0.8s;
    transform-style: preserve-3d;
}

.card:hover .inner {
    transform: rotateY(180deg);
}

.front, .back {
    width: 100%;
    height: 100%;
    position: absolute;
    border-radius: 12px;
    backface-visibility: hidden;
    box-shadow: 0 8px 20px rgba(0,0,0,0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 28px;
    font-weight: bold;
}

/* Front Side */
.front {
    background: white;
    flex-direction: column;
}

.red {
    color: red;
}

.black {
    color: black;
}

/* Back Side */
.back {
    background: repeating-linear-gradient(
        45deg,
        #ff0000,
        #ff0000 10px,
        #ffffff 10px,
        #ffffff 20px
    );
    transform: rotateY(180deg);
    color: white;
    font-size: 20px;
}
</style>
</head>

<body>

<div class="container">

    <!-- Ace of Spades -->
    <div class="card">
        <div class="inner">
            <div class="front black">
                A ♠
            </div>
            <div class="back">
                CARD
            </div>
        </div>
    </div>

    <!-- King of Hearts -->
    <div class="card">
        <div class="inner">
            <div class="front red">
                K ♥
            </div>
            <div class="back">
                CARD
            </div>
        </div>
    </div>

    <!-- Queen of Diamonds -->
    <div class="card">
        <div class="inner">
            <div class="front red">
                Q ♦
            </div>
            <div class="back">
                CARD
            </div>
        </div>
    </div>

    <!-- Jack of Clubs -->
    <div class="card">
        <div class="inner">
            <div class="front black">
                J ♣
            </div>
            <div class="back">
                CARD
            </div>
        </div>
    </div>

</div>

</body>
</html>
