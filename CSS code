body {
  margin: 0;
  font-family: Arial, sans-serif;
  background-color: #000;
  color: #fff;
}

.navbar {
  display: flex;
  justify-content: space-between;
  padding: 20px;
}

.logo {
  width: 120px;
}

.signin {
  background: red;
  color: white;
  border: none;
  padding: 10px 20px;
  cursor: pointer;
}

.hero {
  text-align: center;
  padding: 100px 20px;
  background: url('images/hero-bg.jpg') center/cover no-repeat;
}

.hero h1 {
  font-size: 3rem;
}

.email-signup {
  margin-top: 20px;
}

.email-signup input {
  padding: 10px;
  width: 300px;
}

.email-signup button {
  padding: 10px 20px;
  background: red;
  color: white;
  border: none;
  cursor: pointer;
}

.features {
  display: flex;
  justify-content: space-around;
  padding: 50px;
}

.feature {
  width: 40%;
  text-align: center;
}

footer {
  text-align: center;
  padding: 20px;
  background: #111;
}
